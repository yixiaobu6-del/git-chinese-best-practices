#!/bin/bash
# Git pre-commit hook - 提交前自动检查
# 安装: 复制到 .git/hooks/pre-commit

echo "🔍 运行提交前检查..."

# 检查是否有未解决的冲突标记
if grep -rn "^<<<<<<< \|^=======$\|^>>>>>>> " --include="*.py" --include="*.js" --include="*.ts" --include="*.md" . 2>/dev/null | grep -v "node_modules/" | grep -v ".git/"; then
    echo "❌ 发现未解决的合并冲突标记！"
    exit 1
fi

# 检查是否包含调试代码
if grep -rn "console\.log\|debugger\|print(" --include="*.py" --include="*.js" --include="*.ts" . 2>/dev/null | grep -v "node_modules/" | grep -v ".git/" | grep -v "# "; then
    echo "⚠️  警告：代码中包含调试语句（仅作提醒，不阻止提交）"
fi

echo "✅ 提交前检查通过"
exit 0
